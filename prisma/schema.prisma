generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  resumes Resume[]
}

model Resume {
  id         Int      @id @default(autoincrement())
  content    String
  fileName   String
  createdAt  DateTime @default(now())

  userId Int
  user   User @relation(fields: [userId], references: [id])
}